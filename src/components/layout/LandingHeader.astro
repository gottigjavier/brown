---
import Logo from "./Logo.astro"
import Redes from "./Redes.astro"
const { color } = Astro.props;
const textColor = `text-${color}`;
---

<header
  id="landing-header"
  class=`py-3 px-2 flex items-center fixed top-0 w-full justify-between z-40`
>
<nav class="flex flex-grow justify-start basis-0">
  <ul class="flex text-sm [&>li>a]:duration-500 [&>li>a]:inline-block [&>li>a]:px-2">
    <li id="logo" title="Página de Bienvenida" class="block">
      <a href="/">
        <Logo/>
      </a>
    </li>
  </ul>
</nav>

  <!-- Mobile hamburger -->
  <button id="hamburger" class="sm:hidden z-50 p-2" aria-label="Menú">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-white"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
  </button>

  <nav class="hidden sm:flex flex-grow justify-end basis-0">
    <ul
      class="right-nav sm:flex [&>li>a]:transition-colors [&>li>a]:duration-500 [&>li>a]:text-current [&>li>a]:font-medium [&>li>a]:inline-block [&>li>a]:px-3 [&>li>a]:pb-1"
    >
    <li class="block"><a href="/">Bienvenida</a></li>
      <li class="block"><a href="/galeria">Galería</a></li>
      <li class="block"><a href="/trabajos">Realizaciones</a></li>
      <li class="block"><a id="open-modal" href="#">Contacto</a></li>
    </ul>
  </nav>

  <!-- Mobile menu overlay -->
  <div id="mobile-menu" class="fixed inset-0 bg-black/95 backdrop-blur-lg z-40 hidden flex-col items-center justify-center gap-8">
    <a class="text-white text-2xl tracking-wider" href="/">Bienvenida</a>
    <a class="text-white text-2xl tracking-wider" href="/galeria">Galería</a>
    <a class="text-white text-2xl tracking-wider" href="/trabajos">Realizaciones</a>
    <a class="text-white text-2xl tracking-wider" id="open-modal-mobile" href="#">Contacto</a>
  </div>
  
  <div
  id="menu-backdrop"
  class={`
      absolute bg-white/5 backdrop-blur-lg rounded
      translate-x-[var(--left)] translate-y-[var(--top)]
      left-0 top-0
      w-[var(--width)] h-[var(--height)]
      transition-all duration-500
      ease-in-out opacity-0 -z-10
      `}
  >

</div>
<Redes />
</header>

<script>
  const listItem = document.querySelectorAll("#landing-header li")
  const menuBackDrop = document.querySelector("#menu-backdrop") as HTMLElement

  listItem.forEach((item) => {
    item.addEventListener("mouseenter", () => {
      const { left, top, width, height } = item.getBoundingClientRect()

      menuBackDrop.style.setProperty("--left", `${left}px`)
      menuBackDrop.style.setProperty("--top", `${top}px`)
      menuBackDrop.style.setProperty("--width", `${width}px`)
      menuBackDrop.style.setProperty("--height", `${height}px`)

      menuBackDrop.style.opacity = "1"
      menuBackDrop.style.visibility = "visible"
    })

    item.addEventListener("mouseleave", () => {
      menuBackDrop.style.opacity = "0"
      menuBackDrop.style.visibility = "hidden"
    })
  })

  // Hamburger toggle
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  if (hamburger && mobileMenu) {
    hamburger.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden', isOpen);
      mobileMenu.classList.toggle('flex', !isOpen);
      hamburger.innerHTML = isOpen
        ? `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-white"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>`
        : `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-white"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`;
    });

    // Close mobile menu on nav click
    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        mobileMenu.classList.remove('flex');
        hamburger.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-white"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>`;
      });
    });
  }
</script>

<script is:inline>
    function detachScene(){
    const pant0 = document.getElementById("pantalla0");
    console.log("detachhhhhhhh");
    pant0.remove();
  }
</script>

<style>
  
  .right-nav {
    font-size: 0.8rem;
    text-shadow: -1px -1px 1px #b96300, 1px -1px 1px #333, -1px 1px 1px #333, 1px 1px 1px #333;
  }


@media (max-width: 460px) and (orientation: portrait) {

  .right-nav {
    padding: 5px 0;
    text-align: end;
    font-size: 0.6rem;
  }
}

@media (max-height: 460px) and (orientation: landscape) {
  .right-nav {
    margin-top: 0;
    font-size: 0.6rem;
  }
}

</style>
