---
const { xhref, xsrc, xalt, xtext, xcaption } = Astro.props;
---

<div class="thumbnail shdw">

    <figure>
        <figcaption>
            <i> {xtext}</i>
        </figcaption>
        <a href={xhref} target="_blank" title={xalt}
        ><img src={xsrc} alt={xalt} loading="lazy" /></a
        >
            <small class="flex justify-end"><i> {xcaption}</i></small>
        
    </figure>
    
</div>

<style>
    .thumbnail {
        margin: 0;
        background-color: rgb(21, 32, 32);
        border-radius: 2%;
        max-width: 100%;
        height: 100%;
        transition: transform 0.4s ease;
    }
    .thumbnail:hover {
        transform: scale(1.03);
    }
    figure{
        width: 100%;
        padding: 10px;
        margin: 0;
    }
    figcaption{
        width: 100%;
        color: aliceblue;
        font-family:'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode', Geneva, Verdana, sans-serif;
        text-wrap: pretty;
        padding: 0 0 10px 0;
        font-size: clamp(0.75rem, 1.2vw, 0.95rem);
    }
    img{
        width: 100%;
        aspect-ratio: 16/9;
        object-fit: cover;
        border-radius: 2%;
    }

    small {
        padding: 0.5vw 0.5vw 0 0;
        display: block;
    }

    .shdw {
        box-shadow: 0 8px 16px 0 rgba(253, 253, 253, 0.2), 0 6px 20px 0 rgba(128, 128, 128, 0.699);
    }

    .shdw:hover {
        box-shadow: 0 12px 16px 0 rgba(253, 211, 96, 0.24), 0 17px 50px 0 rgba(253, 211, 96, 0.12);
    }

</style>
