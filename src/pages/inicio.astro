---
import FlyDrone from "../components/indexcomp/FlyDrone.astro";
import VideoInicial from "../components/indexcomp/VideoInicial.astro";
import LandingHeader from "../components/layout/LandingHeader.astro";
import BuqueDesdemona from "../components/indexcomp/BuqueDesdemona.astro";
import ThompsonPNA from "../components/indexcomp/ThompsonPNA.astro";
import ModalGoogle from "../components/layout/ModalGoogle.astro";
import Pantalla2 from "../components/indexcomp/Pantalla2.astro";
import Pantalla3 from "../components/indexcomp/Pantalla3.astro";
import LayoutInicio from "../layouts/LayoutInicio.astro";
import Reveal from "../components/layout/Reveal.astro";
---

<LayoutInicio title="Dron Video 360">
  <div>
    <LandingHeader color="white" />
  </div>
  <div
    id="scroll-container"
    class="snap-y snap-mandatory relative w-full h-screen overflow-y-auto overflow-x-hidden scroll-none"
  >
    <div id="pantalla1" class="snap-center">
      <Reveal>
        <VideoInicial />
      </Reveal>
    </div>
    <div id="pantalla2" class="snap-center">
      <Reveal>
        <Pantalla2 />
      </Reveal>
    </div>
    <div id="pantalla3" class="snap-center">
      <Reveal>
        <Pantalla3 />
      </Reveal>
    </div>
    <div id="pantalla4" class="snap-center">
      <Reveal>
        <BuqueDesdemona />
      </Reveal>
    </div>
    <div id="pantalla5" class="snap-center">
      <Reveal>
        <ThompsonPNA />
      </Reveal>
    </div>
    <div id="pantalla6" class="snap-center">
      <Reveal>
        <FlyDrone />
      </Reveal>
    </div>
    <div class="snap-center">
      <Reveal>
        <ModalGoogle />
      </Reveal>
    </div>
  </div>
</LayoutInicio>

<script>
  const container = document.getElementById('scroll-container');
  const parallaxImgs = document.querySelectorAll('.parallax-img');

  if (container && parallaxImgs.length) {
    container.addEventListener('scroll', () => {
      const scrollTop = container.scrollTop;
      const containerHeight = container.clientHeight;
      parallaxImgs.forEach((img) => {
        const rect = img.closest('.landing-section')?.getBoundingClientRect();
        if (rect) {
          const offset = (rect.top - containerHeight) / containerHeight;
          const translateY = Math.max(-15, Math.min(15, offset * 8));
          img.style.objectPosition = `50% ${50 + translateY}%`;
        }
      });
    });
  }
</script>
